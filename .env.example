# Friendly Captcha credentials — get these from https://app.friendlycaptcha.com
# (Application -> Sitekey, and API Keys -> create one)
FRC_SITEKEY=FCMxxxxxxxxxxxx
FRC_API_KEY=

# 'eu' (default) keeps verification traffic in the EU region.
# Use 'global' to route via the closest Friendly Captcha edge.
FRC_ENDPOINT=eu

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
